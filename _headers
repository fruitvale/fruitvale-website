# Cloudflare Pages headers -- https://developers.cloudflare.com/pages/configuration/headers/
# Applied by Cloudflare at the edge. (The local python preview server ignores this
# file, so the CSP below must be tested on the *.pages.dev preview, not localhost.)

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://docs.google.com; frame-src https://www.google.com https://maps.google.com; form-action 'self'; frame-ancestors 'none'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests

# Long-cache fingerprint-free static assets (images rarely change)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# CSS/JS are cache-busted with ?v=N in the HTML, so a day is safe
/css/*
  Cache-Control: public, max-age=86400
/js/*
  Cache-Control: public, max-age=86400
